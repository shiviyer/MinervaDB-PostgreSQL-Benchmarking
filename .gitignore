# =============================================================================
# MinervaDB PostgreSQL Benchmarking Toolkit
# .gitignore - Files to exclude from version control
# =============================================================================

# =============================================================================
# Benchmark Results (generated at runtime - do not commit)
# =============================================================================
results/
*.results.txt
*.pgbench-log*
pgbench_log.*
/tmp/minervadb-*

# =============================================================================
# Generated Reports
# =============================================================================
reports/output/
reports/*.pdf
reports/*.html
!reports/templates/
!reports/sample-outputs/

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/
*.csv
!reports/sample-outputs/*.csv

# =============================================================================
# Credentials and Secrets (NEVER commit these)
# =============================================================================
.env
.env.*
*.pgpass
pgpass
*password*
*secret*
*credential*
userlist.txt
pgbouncer.conf
!pgbouncer.conf.example

# =============================================================================
# HammerDB Runtime Files
# =============================================================================
*.hdb
hammerdb_*.log
hammerdb-*.tcl
/tmp/hammerdb-*

# =============================================================================
# Operating System
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.swp
*.swo
*~
.#*

# =============================================================================
# Editor / IDE
# =============================================================================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.vim/
.nvim/

# =============================================================================
# Logs
# =============================================================================
*.log
!logs/
logs/
postgresql-*.log

# =============================================================================
# Temporary Files
# =============================================================================
/tmp/
*.tmp
*.bak
*.backup

# =============================================================================
# Test Data (large files)
# =============================================================================
*.data
*.dump
*.sql.gz
*.pgdump

# =============================================================================
# Monitoring Data
# =============================================================================
prometheus-data/
grafana-data/
node_exporter-*.tar.gz
